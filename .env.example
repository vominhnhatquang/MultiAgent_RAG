# ─── RAG Chatbot — Environment Variables ──────────────────────────────────────
# Copy: cp .env.example .env   then fill in secrets

# === Application ===
APP_ENV=production              # production | development
APP_DEBUG=false
SECRET_KEY=change-me-64-char-random-string
CORS_ORIGINS=http://localhost:3000
STRICT_GUARD_THRESHOLD=0.7

# === PostgreSQL ===
PG_USER=raguser
PG_PASSWORD=changeme_pg_password
PG_DB=ragdb
PG_HOST=postgres
PG_PORT=5432
DATABASE_URL=postgresql+asyncpg://${PG_USER}:${PG_PASSWORD}@${PG_HOST}:${PG_PORT}/${PG_DB}
# Aliases required by docker-compose healthcheck
POSTGRES_USER=${PG_USER}
POSTGRES_PASSWORD=${PG_PASSWORD}
POSTGRES_DB=${PG_DB}

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === Qdrant ===
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=document_chunks

# === Ollama (10GB RAM — only 1 model loaded at a time) ===
OLLAMA_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=gemma2:9b     # Fits within 6500m budget
OLLAMA_HEAVY_MODEL=llama3.1:8b  # Alternative (swap with gemma2 if needed)
OLLAMA_RERANK_MODEL=bge-reranker
OLLAMA_TIMEOUT=120

# === RAG Settings ===
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_RERANK_TOP_K=3

# === Gemini API (optional cloud fallback) ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# === Monitoring & Alerts ===
ALERT_WEBHOOK_URL=              # Slack/Discord webhook for RAM > 9GB alerts
# Slack:   https://hooks.slack.com/services/T.../B.../...
# Discord: https://discord.com/api/webhooks/.../...

# === Cloudflare Tunnel (public access) ===
CLOUDFLARE_TUNNEL_TOKEN=        # Get from Cloudflare Zero Trust dashboard
NGROK_AUTHTOKEN=                # Alternative: ngrok auth token

# === Container names (used by backup/restore scripts) ===
POSTGRES_CONTAINER=rag_postgres
